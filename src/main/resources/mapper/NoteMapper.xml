<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ysx.agent.mapper.NoteMapper">

    <resultMap id="BaseResultMap" type="com.ysx.agent.domain.Note">
        <id property="id" column="id" />
        <result property="kbId" column="kb_id" />
        <result property="title" column="title" />
        <result property="content" column="content" />
        <result property="contentBytes" column="content_bytes" />
        <result property="summary" column="summary" />
        <result property="createdAt" column="created_at" />
        <result property="updatedAt" column="updated_at" />
    </resultMap>

    <sql id="Base_Column_List">
        id, kb_id, title, content, content_bytes, summary,
        created_at, updated_at
    </sql>

    <select id="selectByKbId" resultMap="BaseResultMap">
        select
        <include refid="Base_Column_List" />
        from note
        where kb_id = #{kbId}
        order by id desc
    </select>

    <select id="selectByIdAndKbId" resultMap="BaseResultMap">
        select
        <include refid="Base_Column_List" />
        from note
        where id = #{id}
          and kb_id = #{kbId}
        limit 1
    </select>
</mapper>
